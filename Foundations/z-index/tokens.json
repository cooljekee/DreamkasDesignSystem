{
  "primitive": {
    "z": {
      "0": 0,
      "10": 10,
      "100": 100,
      "1000": 1000,
      "2000": 2000,
      "3000": 3000
    }
  },
  "semantic": {
    "z-raised": "var(--z-10)",
    "z-sticky": "var(--z-100)",
    "z-dropdown": "var(--z-1000)",
    "z-overlay": "var(--z-2000)",
    "z-modal": "calc(var(--z-2000) + 10)",
    "z-toast": "var(--z-3000)"
  }
}
