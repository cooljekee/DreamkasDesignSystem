{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "font": {
    "family": {
      "sans": {
        "$value": "'Dreamkas Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "ui-monospace, 'SF Mono', Menlo, Monaco, monospace",
        "$type": "fontFamily"
      }
    },
    "weight": {
      "regular": {
        "$value": 400,
        "$type": "fontWeight"
      },
      "medium": {
        "$value": 500,
        "$type": "fontWeight"
      },
      "bold": {
        "$value": 700,
        "$type": "fontWeight"
      }
    },
    "size": {
      "10": {
        "$value": "10px",
        "$type": "dimension"
      },
      "12": {
        "$value": "12px",
        "$type": "dimension"
      },
      "13": {
        "$value": "13px",
        "$type": "dimension"
      },
      "14": {
        "$value": "14px",
        "$type": "dimension"
      },
      "16": {
        "$value": "16px",
        "$type": "dimension"
      },
      "20": {
        "$value": "20px",
        "$type": "dimension"
      },
      "24": {
        "$value": "24px",
        "$type": "dimension"
      },
      "32": {
        "$value": "32px",
        "$type": "dimension"
      }
    },
    "lineHeight": {
      "flat": {
        "$value": 1,
        "$type": "number"
      },
      "tight": {
        "$value": 1.25,
        "$type": "number"
      },
      "snug": {
        "$value": 1.3,
        "$type": "number"
      },
      "normal": {
        "$value": 1.4,
        "$type": "number"
      },
      "relaxed": {
        "$value": 1.5,
        "$type": "number"
      }
    }
  },
  "typography": {
    "h1": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.bold}",
        "fontSize": "{font.size.32}",
        "lineHeight": "{font.lineHeight.tight}",
        "letterSpacing": "-0.01em"
      },
      "$type": "typography",
      "$description": "Заголовок страницы"
    },
    "h2": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.bold}",
        "fontSize": "{font.size.24}",
        "lineHeight": "{font.lineHeight.snug}",
        "letterSpacing": "-0.01em"
      },
      "$type": "typography",
      "$description": "Заголовок большой секции"
    },
    "h3": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.bold}",
        "fontSize": "{font.size.20}",
        "lineHeight": "{font.lineHeight.snug}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Заголовок подсекции, диалога"
    },
    "h4": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.medium}",
        "fontSize": "{font.size.16}",
        "lineHeight": "{font.lineHeight.normal}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Заголовок карточки или плашки"
    },
    "subtitle": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.bold}",
        "fontSize": "{font.size.14}",
        "lineHeight": "{font.lineHeight.normal}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Жирные подписи, label полей формы"
    },
    "body": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize": "{font.size.14}",
        "lineHeight": "{font.lineHeight.relaxed}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Основной текст параграфов и таблиц"
    },
    "body-sm": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize": "{font.size.13}",
        "lineHeight": "{font.lineHeight.relaxed}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Вторичный текст, описания"
    },
    "caption": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize": "{font.size.12}",
        "lineHeight": "{font.lineHeight.normal}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Helper-текст, заголовки колонок таблицы"
    },
    "button": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.medium}",
        "fontSize": "{font.size.13}",
        "lineHeight": "{font.lineHeight.flat}",
        "letterSpacing": "0.06em",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "$description": "UPPERCASE кнопки и табы"
    },
    "button-text": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.medium}",
        "fontSize": "{font.size.14}",
        "lineHeight": "{font.lineHeight.flat}",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Текстовые кнопки в обычном регистре"
    },
    "overline": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.medium}",
        "fontSize": "{font.size.10}",
        "lineHeight": "{font.lineHeight.normal}",
        "letterSpacing": "0.08em",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "$description": "Микро-метки, бейджи"
    }
  }
}