{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "shadow": {
    "_tint": {
      "$value": "0 17 19",
      "$type": "string",
      "$description": "RGB-компоненты neutral-950, через space (для rgba(var() / alpha))"
    },
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "sm": {
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "rgba(0,17,19,0.06)" },
        { "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px", "color": "rgba(0,17,19,0.08)" }
      ],
      "$type": "shadow",
      "$description": "Subtle resting — карточки в покое"
    },
    "md": {
      "$value": [
        { "offsetX": "0px", "offsetY": "4px",  "blur": "6px",  "spread": "-2px", "color": "rgba(0,17,19,0.06)" },
        { "offsetX": "0px", "offsetY": "12px", "blur": "24px", "spread": "-4px", "color": "rgba(0,17,19,0.12)" }
      ],
      "$type": "shadow",
      "$description": "Floating — dropdown, popover, menu, tooltip, fab, card-hover, sticky"
    },
    "lg": {
      "$value": [
        { "offsetX": "0px", "offsetY": "12px", "blur": "16px", "spread": "-4px",  "color": "rgba(0,17,19,0.10)" },
        { "offsetX": "0px", "offsetY": "32px", "blur": "56px", "spread": "-10px", "color": "rgba(0,17,19,0.20)" }
      ],
      "$type": "shadow",
      "$description": "Overlay — modal, drawer, toast"
    },
    "focus-ring": {
      "$value": [
        { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "3px", "color": "rgba(0,151,167,0.24)" }
      ],
      "$type": "shadow",
      "$description": "Кольцо фокуса вокруг интерактивных контролов"
    },
    "focus-ring-danger": {
      "$value": [
        { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "3px", "color": "rgba(229,57,53,0.24)" }
      ],
      "$type": "shadow",
      "$description": "Кольцо фокуса для контролов с ошибкой"
    }
  },
  "semantic": {
    "shadow": {
      "card":         { "$value": "{shadow.sm}", "$type": "shadow" },
      "card-hover":   { "$value": "{shadow.md}", "$type": "shadow" },
      "sticky":       { "$value": "{shadow.md}", "$type": "shadow" },
      "dropdown":     { "$value": "{shadow.md}", "$type": "shadow" },
      "popover":      { "$value": "{shadow.md}", "$type": "shadow" },
      "menu":         { "$value": "{shadow.md}", "$type": "shadow" },
      "tooltip":      { "$value": "{shadow.md}", "$type": "shadow" },
      "fab":          { "$value": "{shadow.md}", "$type": "shadow" },
      "modal":        { "$value": "{shadow.lg}", "$type": "shadow" },
      "drawer":       { "$value": "{shadow.lg}", "$type": "shadow" },
      "dialog":       { "$value": "{shadow.lg}", "$type": "shadow" },
      "toast":        { "$value": "{shadow.lg}", "$type": "shadow" },
      "fab-hover":    { "$value": "{shadow.lg}", "$type": "shadow" },
      "focus":        { "$value": "{shadow.focus-ring}",        "$type": "shadow" },
      "focus-danger": { "$value": "{shadow.focus-ring-danger}", "$type": "shadow" }
    }
  }
}
